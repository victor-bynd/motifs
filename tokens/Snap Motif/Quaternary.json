{
  "Header": {
    "--global-header-bg-color": {
      "value": "{Root.--color-bg-surface}",
      "type": "color"
    },
    "--global-header-navigator-item-font-text-transform": {
      "value": "none",
      "type": "textCase"
    }
  },
  "Block": {
    "--block-title-de-emphasized-color": {
      "value": "{Root.--color-fg-muted}",
      "type": "color",
      "description": "color for de-emphasized text, applicable only on H1 and H2 (optional)"
    },
    "--block-title-font-size": {
      "value": "{Root.--h2-font-size}",
      "type": "fontSizes"
    },
    "--block-title-font-line-height": {
      "value": "{Root.--h2-font-line-height}",
      "type": "lineHeights"
    },
    "--block-header-padding": {
      "value": "{Root.--spacing-16} {Root.--spacing-32}",
      "type": "spacing"
    },
    "--block-boundary-padding": {
      "value": "{Root.--spacing-32}",
      "type": "spacing"
    }
  },
  "Hero": {
    "--hero-title-de-emphasized-color": {
      "value": "{Root.--color-fg-muted}",
      "type": "color"
    }
  },
  "Footer": {
    "--footer-bg-color": {
      "value": "{Root.--color-bg-subtle}",
      "type": "color"
    },
    "--footer-border-color": {
      "value": "{Root.--color-border-muted}",
      "type": "color"
    },
    "--footer-divider-border-color": {
      "value": "{Root.--color-border-muted}",
      "type": "color"
    },
    "--footer-bar-bg-color": {
      "value": "{Root.--color-bg-subtle}",
      "type": "color"
    },
    "--footer-bar-divider-border-color": {
      "value": "{Root.--color-border-muted}",
      "type": "color"
    },
    "--footer-font-size": {
      "value": "14px",
      "type": "fontSizes"
    },
    "--footer-bar-header-font-text-transform": {
      "value": "none",
      "type": "textCase"
    }
  },
  "Toggle Slider": {
    "--toggle-slider-bg-color": {
      "value": "{Root.--color-bg-inverse}",
      "type": "color"
    },
    "--toggle-slider-active-color": {
      "value": "{Root.--color-bg-brand}",
      "type": "color"
    }
  },
  "Toggle Button": {
    "--toggle-button-color": {
      "value": "{Root.--color-fg-inverse}",
      "type": "color"
    }
  },
  "Accordion": {
    "--accordion-divider-border-color": {
      "value": "{Root.--color-border-muted}",
      "type": "color"
    },
    "--accordion-header-font-size": {
      "value": "{Root.--h6-font-size}",
      "type": "fontSizes"
    },
    "--accordion-header-font-line-height": {
      "value": "{Root.--h6-font-line-height}",
      "type": "lineHeights"
    },
    "--accordion-header-font-weight": {
      "value": "{Root.--h6-font-weight}",
      "type": "fontWeights"
    }
  },
  "Banner": {
    "--banner-bg-color": {
      "value": "{Root.--color-bg-subtle}",
      "type": "color"
    }
  },
  "Side Navigation": {
    "--side-navigation-mobile-bg-color": {
      "value": "{Root.--color-bg-subtle-hover}",
      "type": "color"
    }
  },
  "Form": {
    "--form-input-border-color": {
      "value": "{Root.--color-border-muted}",
      "type": "color"
    },
    "--form-input-font-size": {
      "value": "{Root.--text-font-size}",
      "type": "fontSizes"
    },
    "--form-input-font-line-height": {
      "value": "normal",
      "type": "lineHeights"
    },
    "--form-input-font-weight": {
      "value": "{Root.--text-font-weight}",
      "type": "fontWeights"
    }
  },
  "Progress Bar": {
    "--progress-bar-progress-color": {
      "value": "{Root.--color-bg-brand}",
      "type": "color"
    }
  },
  "Toggle Panel": {
    "--toggle-panel-bg-color": {
      "value": "{Root.--color-bg-inverse}",
      "type": "color"
    }
  },
  "Primitive Table": {
    "--table-bg-color": {
      "value": "transparent",
      "type": "color"
    },
    "--table-border-color": {
      "value": "{Root.--color-border-moderate}",
      "type": "color"
    },
    "--table-cell-body-bg-color": {
      "value": "{Root.--color-bg-subtle}",
      "type": "color"
    },
    "--table-cell-header-bg-color": {
      "value": "{Root.--color-bg-subtle-active}",
      "type": "color"
    },
    "--table-cell-padding": {
      "value": "{Root.--spacing-32} {Root.--spacing-16}",
      "type": "spacing"
    },
    "--table-row-gap": {
      "value": "0",
      "type": "spacing"
    }
  },
  "Autocomplete": {
    "--autocomplete-border-color": {
      "value": "{Root.--color-border-muted}",
      "type": "color"
    },
    "--autocomplete-font-size": {
      "value": "{Root.--text-font-size}",
      "type": "fontSizes"
    },
    "--autocomplete-font-weight": {
      "value": "{Root.--text-font-weight}",
      "type": "fontWeights"
    }
  },
  "Definition": {
    "--definition-active-bg-color": {
      "value": "{Root.--color-bg-brand-emphasis}",
      "type": "color"
    },
    "--definition-active-border-color": {
      "value": "{Root.--color-bg-brand-hover}",
      "type": "color"
    },
    "--definition-bg-color": {
      "value": "{Root.--color-bg-recessed}",
      "type": "color"
    },
    "--definition-border-color": {
      "value": "{Root.--color-bg-brand-hover}",
      "type": "color"
    },
    "--definition-hover-bg-color": {
      "value": "{Root.--color-bg-subtle-active}",
      "type": "color"
    },
    "--definition-hover-border-color": {
      "value": "{Root.--color-bg-brand-hover}",
      "type": "color"
    }
  },
  "Topic": {
    "--topic-hover-bg-color": {
      "value": "{Root.--color-bg-subtle-active}",
      "type": "color"
    }
  }
}